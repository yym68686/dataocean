DATAOCEAN_PORT=8080
POSTGRES_DB=dataocean
POSTGRES_USER=dataocean
POSTGRES_PASSWORD=change-me

# Local non-Docker API development can use:
# DATABASE_URL=postgres://dataocean:change-me@localhost:5432/dataocean

# Zhupay V2 real connector. Keep private/public keys quoted with \n escapes
# when setting them as single-line environment variables.
ZHUPAY_BASE_URL=https://pay.lxsd.cn
ZHUPAY_PID=
ZHUPAY_MERCHANT_PRIVATE_KEY=
ZHUPAY_PLATFORM_PUBLIC_KEY=
ZHUPAY_SYNC_ENABLED=false
ZHUPAY_SYNC_INTERVAL_MS=60000
ZHUPAY_SYNC_MAX_PAGES=4
ZHUPAY_SYNC_LIMIT=50

# Creem real connector. Use a live creem_ key for production or a
# creem_test_ key for sandbox. DataOcean keeps this server-side.
CREEM_BASE_URL=
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_CURRENCY=USD
CREEM_SYNC_ENABLED=false
CREEM_SYNC_INTERVAL_MS=3600000
CREEM_SYNC_MAX_PAGES=4
CREEM_SYNC_PAGE_SIZE=50

# Aggregated revenue reporting. Set FX rates only when you want Command
# Center totals to combine providers with different native currencies.
DATAOCEAN_REPORTING_CURRENCY=USD
DATAOCEAN_FX_CNY_TO_USD=
DATAOCEAN_FX_USD_TO_CNY=
